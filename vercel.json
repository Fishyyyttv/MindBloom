{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/chat/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/webhooks/stripe/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/notifications/dispatch/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/notifications/dispatch?kind=daily",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/notifications/dispatch?kind=weekly",
      "schedule": "0 17 * * 1"
    }
  ]
}
